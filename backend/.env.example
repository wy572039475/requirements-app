# 服务配置
PORT=3003
NODE_ENV=development
FRONTEND_URL=http://localhost:5177

# MongoDB 配置
MONGODB_URI=mongodb://localhost:27017/requirements-app
USE_MOCK_DB=false

# JWT 配置（必填，必须设置一个强密钥）
JWT_SECRET=your-jwt-secret-key-change-this-in-production

# 智谱AI 配置（需求评审、需求拆解和接口分析）
ZHIPUAI_API_KEY=your-zhipuai-api-key-here
# ZHIPU_API_KEY=your-zhipuai-api-key-here (备选变量名)
ZHIPUAI_MODEL=glm-4-flash

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
